# Standard keys start with AIza; new auth keys from AI Studio start with AQ.
# This service reads ai-service/.env first. If Windows also has GEMINI_API_KEY set,
# remove the old system variable or it may confuse other tools.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
BACKEND_API_URL=http://localhost:3000/api/v1
