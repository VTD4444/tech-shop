DATABASE_URL=postgresql://techshop:techshop_pass@localhost:5433/techshop

# Redis (product search cache)
REDIS_URL=redis://localhost:6379
REDIS_PRODUCTS_CACHE_TTL=300
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# VNPAY
VNPAY_ENV=sandbox
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3001/vnpay/return
VNPAY_IPN_WHITELIST=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=techshop/products

# Resend — see docs/RESEND_INTEGRATION.md
RESEND_API_KEY=re_your_api_key
MAIL_FROM=TechShop <onboarding@resend.dev>

# App
AI_SERVICE_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:3001
PORT=3000
UNPAID_ORDER_TIMEOUT_HOURS=24

# Observability
SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=development
