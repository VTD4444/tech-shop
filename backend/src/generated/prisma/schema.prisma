generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
  output       = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           BigInt   @id @default(autoincrement()) @map("id")
  username     String   @unique @map("username")
  email        String   @unique @map("email")
  passwordHash String   @map("password_hash")
  role         String   @default("customer") @map("role")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  addresses           UserAddress[]
  cartItems           CartItem[]
  wishlists           Wishlist[]
  reviews             ProductRating[]
  comments            ProductComment[]
  orders              Order[]
  savedBuilds         SavedBuild[]
  passwordResetTokens PasswordResetToken[]

  @@index([email], name: "idx_users_email")
  @@map("users")
}

model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash], name: "idx_password_reset_token_hash")
  @@map("password_reset_tokens")
}

model UserAddress {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  receiverName String   @map("receiver_name")
  phone        String
  addressLine  String   @map("address_line")
  ward         String?
  district     String?
  city         String?
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Category {
  id        BigInt   @id @default(autoincrement())
  name      String
  slug      String   @unique
  parentId  BigInt?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryParent")
  products Product[]

  @@unique([name, parentId], name: "unique_category_name_parent")
  @@map("categories")
}

model Brand {
  id   BigInt @id @default(autoincrement())
  name String @unique
  slug String @unique

  products Product[]

  @@map("brands")
}

model Product {
  id              BigInt   @id @default(autoincrement())
  categoryId      BigInt?  @map("category_id")
  brandId         BigInt?  @map("brand_id")
  name            String
  slug            String   @unique
  price           Decimal  @db.Decimal(12, 2)
  stockQuantity   Int      @default(0) @map("stock_quantity")
  imageUrl        String?  @map("image_url")
  description     String?  @db.Text
  longDescription String?  @map("long_description") @db.Text
  isPcComponent   Boolean  @default(false) @map("is_pc_component")
  aiTags          String[] @map("ai_tags")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand           Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images          ProductImage[]
  spec            ProductSpec?
  pcComponent     PcComponent?
  cartItems       CartItem[]
  wishlists       Wishlist[]
  ratings         ProductRating[]
  comments        ProductComment[]
  orderItems      OrderItem[]
  savedBuildItems SavedBuildItem[]

  @@index([categoryId], name: "idx_products_category_id")
  @@index([brandId], name: "idx_products_brand_id")
  @@index([price], name: "idx_products_price")
  @@index([status], name: "idx_products_status")
  @@index([isPcComponent], name: "idx_products_is_pc_component")
  @@index([aiTags], name: "idx_products_ai_tags", type: Gin)
  @@map("products")
}

model ProductImage {
  id        BigInt  @id @default(autoincrement())
  productId BigInt  @map("product_id")
  imageUrl  String  @map("image_url")
  isMain    Boolean @default(false) @map("is_main")
  sortOrder Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductSpec {
  id              BigInt   @id @default(autoincrement())
  productId       BigInt   @unique @map("product_id")
  cpuBrand        String?  @map("cpu_brand")
  cpuSeries       String?  @map("cpu_series")
  cpuModel        String?  @map("cpu_model")
  ramCapacity     Int?     @map("ram_capacity")
  ramGeneration   String?  @map("ram_generation")
  storageCapacity Int?     @map("storage_capacity")
  storageType     String?  @map("storage_type")
  gpuModel        String?  @map("gpu_model")
  screenSize      Decimal? @map("screen_size") @db.Decimal(4, 1)
  specs           Json?    @db.JsonB

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([cpuBrand], name: "idx_product_specs_cpu_brand")
  @@index([ramCapacity], name: "idx_product_specs_ram_capacity")
  @@index([ramGeneration], name: "idx_product_specs_ram_generation")
  @@index([gpuModel], name: "idx_product_specs_gpu_model")
  @@index([specs], name: "idx_product_specs_jsonb", type: Gin)
  @@map("product_specs")
}

model PcComponent {
  id                   BigInt   @id @default(autoincrement())
  productId            BigInt   @unique @map("product_id")
  componentType        String   @map("component_type")
  socket               String?
  chipset              String?
  ramGeneration        String?  @map("ram_generation")
  ramSlots             Int?     @map("ram_slots")
  maxRamCapacity       Int?     @map("max_ram_capacity")
  ramCapacity          Int?     @map("ram_capacity")
  ramBus               Int?     @map("ram_bus")
  formFactor           String?  @map("form_factor")
  gpuLengthMm          Int?     @map("gpu_length_mm")
  maxGpuLengthMm       Int?     @map("max_gpu_length_mm")
  cpuCoolerHeightMm    Int?     @map("cpu_cooler_height_mm")
  maxCpuCoolerHeightMm Int?     @map("max_cpu_cooler_height_mm")
  powerConsumption     Int?     @map("power_consumption")
  powerSupplyWatt      Int?     @map("power_supply_watt")
  pcieVersion          String?  @map("pcie_version")
  storageInterface     String?  @map("storage_interface")
  detailedSpecs        Json?    @map("detailed_specs") @db.JsonB
  updatedAt            DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], name: "idx_pc_components_product_id")
  @@index([componentType], name: "idx_pc_components_type")
  @@index([socket], name: "idx_pc_components_socket")
  @@index([ramGeneration], name: "idx_pc_components_ram_generation")
  @@index([formFactor], name: "idx_pc_components_form_factor")
  @@index([detailedSpecs], name: "idx_pc_components_detailed_specs", type: Gin)
  @@map("pc_components")
}

model CartItem {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  productId BigInt   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId], name: "idx_cart_items_user_id")
  @@index([productId], name: "idx_cart_items_product_id")
  @@map("cart_items")
}

model Wishlist {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  productId BigInt   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model ProductRating {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  productId BigInt   @map("product_id")
  orderId   BigInt?  @map("order_id")
  rating    Int
  images    String[] @default([]) @map("images")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, productId], name: "idx_product_ratings_user_product")
  @@index([productId, createdAt], name: "idx_product_ratings_product_created")
  @@index([productId, rating], name: "idx_product_ratings_product_rating")
  @@map("product_ratings")
}

model ProductComment {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  productId BigInt   @map("product_id")
  parentId  BigInt?  @map("parent_id")
  content   String   @db.Text
  images    String[] @default([]) @map("images")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  parent  ProductComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ProductComment[] @relation("CommentReplies")

  @@index([productId, createdAt], name: "idx_product_comments_product_created")
  @@index([parentId], name: "idx_product_comments_parent")
  @@index([productId, status], name: "idx_product_comments_product_status")
  @@map("product_comments")
}

model Order {
  id              BigInt   @id @default(autoincrement())
  userId          BigInt?  @map("user_id")
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  shippingFee     Decimal  @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  shippingAddress String   @map("shipping_address") @db.Text
  customerName    String   @map("customer_name")
  customerPhone   String   @map("customer_phone")
  note            String?  @db.Text
  status          String   @default("pending")
  paymentStatus   String   @default("unpaid") @map("payment_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  vnpayTxn VnpayTransaction?
  ratings  ProductRating[]

  @@index([userId], name: "idx_orders_user_id")
  @@index([status], name: "idx_orders_status")
  @@index([paymentStatus], name: "idx_orders_payment_status")
  @@map("orders")
}

model OrderItem {
  id              BigInt  @id @default(autoincrement())
  orderId         BigInt  @map("order_id")
  productId       BigInt? @map("product_id")
  productName     String  @map("product_name")
  productSlug     String? @map("product_slug")
  productImageUrl String? @map("product_image_url")
  quantity        Int
  price           Decimal @db.Decimal(12, 2)
  subtotal        Decimal @default(0) @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId], name: "idx_order_items_order_id")
  @@index([productId], name: "idx_order_items_product_id")
  @@map("order_items")
}

model VnpayTransaction {
  id                 BigInt    @id @default(autoincrement())
  orderId            BigInt    @unique @map("order_id")
  vnpayTxnRef        String    @unique @map("vnpay_txn_ref")
  vnpayTransactionNo String?   @map("vnpay_transaction_no")
  amount             Decimal   @db.Decimal(12, 2)
  bankCode           String?   @map("bank_code")
  responseCode       String?   @map("response_code")
  status             String    @default("processing")
  secureHash         String?   @map("secure_hash")
  rawResponse        Json?     @map("raw_response") @db.JsonB
  paymentDate        DateTime? @map("payment_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("vnpay_transactions")
}

model SavedBuild {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  name       String   @default("My Build")
  totalPrice Decimal  @default(0) @map("total_price") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SavedBuildItem[]

  @@map("saved_builds")
}

model SavedBuildItem {
  id            BigInt @id @default(autoincrement())
  buildId       BigInt @map("build_id")
  productId     BigInt @map("product_id")
  componentType String @map("component_type")

  build   SavedBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("saved_build_items")
}
